{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "marky:default",
  "description": "Default capabilities for the Marky main window. Grants the frontend access to window controls, file dialogs, secure store, SQLite recent-files, clipboard, and the OS opener.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-close",
    "core:window:allow-minimize",
    "core:window:allow-maximize",
    "core:window:allow-unmaximize",
    "core:window:allow-is-maximized",
    "core:window:allow-set-focus",
    "core:window:allow-show",
    "core:window:allow-unminimize",
    "core:window:allow-start-dragging",
    "core:window:allow-set-fullscreen",
    "core:window:allow-is-fullscreen",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "store:default",
    "sql:default",
    "opener:default",
    "clipboard-manager:default",
    "process:default",
    "fs:read-all",
    "fs:write-all",
    "fs:read-dirs",
    {
      "identifier": "http:default",
      "allow": [
        { "url": "http://*" },
        { "url": "http://*:*" },
        { "url": "https://*" },
        { "url": "https://*:*" }
      ]
    }
  ]
}
