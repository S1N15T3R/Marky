{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Marky",
  "version": "1.0.0",
  "identifier": "com.marky.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Marky",
        "width": 1280,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "center": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self' 'unsafe-inline' 'wasm-unsafe-eval'; font-src 'self' data:; connect-src 'self' https: http: ipc: http://ipc.localhost http://127.0.0.1:11434 http://localhost:11434 ws: wss:; worker-src 'self' blob:;",
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    },
    "macOSPrivateApi": true
  },
  "bundle": {
    "active": true,
    "targets": ["nsis", "deb", "appimage"],
    "category": "Productivity",
    "shortDescription": "Markdown editor with AI",
    "longDescription": "Marky is a cross-platform desktop markdown editor and viewer with deep AI integration and a hacker aesthetic.",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "homepage": "https://github.com/marky-app/marky",
    "windows": {
      "certificateThumbprint": null,
      "digestAlgorithm": "sha256",
      "timestampUrl": "",
      "nsis": {
        "displayLanguageSelector": true,
        "languages": ["English"],
        "installerIcon": "icons/icon.ico",
        "headerImage": "icons/header.bmp"
      }
    },
    "linux": {
      "deb": {
        "depends": [
          "libwebkit2gtk-4.1-0",
          "libgtk-3-0",
          "libayatana-appindicator3-1",
          "librsvg2-2",
          "libjavascriptcoregtk-4.1-0",
          "libsoup-3.0-0",
          "libssl3",
          "libayatana-indicator3-7"
        ]
      }
    }
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:marky.db"]
    },
    "updater": {
      "endpoints": ["https://github.com/marky-app/marky/releases/latest/download/latest.json"],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXkgLS0tLS0tLS0tLS0tLS0tLS0tLS0tLS0tLS0tLS0tLS0tLS0tLS0tLS0tLS0tLS0tLS0tLS0tLS0tLS0tLS0tLS0tLS0tLS0tLS0tLS0tLS0tLS0tLS0tLS0tLS0tLS0tLS0tLS0tLS0t"
    }
  }
}
